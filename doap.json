{
    "@context": [
        "https://schema.org/",
        "http://usefulinc.com/ns/doap#"
    ],
    "@type": "SoftwareApplication",
    "name": "{{PLUGIN_NAME}}",
    "description": "{{PLUGIN_DESCRIPTION}}",
    "url": "{{REPOSITORY_URL}}",
    "version": "0.1.0",
    "dateCreated": "{{CREATION_DATE}}",
    "dateModified": "{{CREATION_DATE}}",
    "license": "https://opensource.org/licenses/MIT",
    "programmingLanguage": [
        "TypeScript"
    ],
    "runtimePlatform": "Obsidian",
    "applicationCategory": "DesktopApplication",
    "operatingSystem": "macOS, Windows, Linux",
    "author": {
        "@type": "Person",
        "name": "{{AUTHOR_NAME}}",
        "url": "{{AUTHOR_URL}}"
    },
    "repository": {
        "@type": "SoftwareSourceCode",
        "url": "{{REPOSITORY_URL}}",
        "programmingLanguage": "TypeScript",
        "license": "https://opensource.org/licenses/MIT",
        "codeRepository": "{{REPOSITORY_URL}}"
    },
    "issueTracker": "{{REPOSITORY_URL}}/issues",
    "releaseNotes": "{{REPOSITORY_URL}}/releases",
    "changelog": {
        "@type": "WebPage",
        "url": "{{REPOSITORY_URL}}/blob/main/CHANGELOG.md",
        "description": "Plugin changelog with version history"
    },
    "keywords": [
        "obsidian",
        "obsidian-plugin",
        "{{KEYWORD_1}}",
        "{{KEYWORD_2}}"
    ],
    "featureList": [
        "{{FEATURE_1}}",
        "{{FEATURE_2}}"
    ],
    "softwareRequirements": [
        {
            "@type": "SoftwareApplication",
            "name": "Obsidian",
            "version": "{{MIN_OBSIDIAN_VERSION}}"
        }
    ],
    "buildSystem": {
        "@type": "SoftwareApplication",
        "name": "esbuild",
        "version": "0.25+"
    },
    "dependencies": [
        {
            "@type": "SoftwareApplication",
            "name": "TypeScript",
            "version": "5.0+"
        }
    ],
    "obsidianPluginId": "{{PLUGIN_ID}}",
    "obsidianMinVersion": "{{MIN_OBSIDIAN_VERSION}}",
    "releases": [
        {
            "@type": "SoftwareRelease",
            "version": "{{RELEASE_VERSION}}",
            "url": "{{REPOSITORY_URL}}/releases/tag/v{{RELEASE_VERSION}}",
            "releaseDate": "{{RELEASE_DATE}}",
            "description": "{{RELEASE_DESCRIPTION}}"
        }
    ],
    "relatedProjects": [
        {
            "@type": "SoftwareApplication",
            "name": "{{RELATED_PROJECT_NAME}}",
            "url": "{{RELATED_PROJECT_URL}}",
            "description": "{{RELATED_PROJECT_DESCRIPTION}}"
        }
    ]
}
