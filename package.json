{
  "name": "zettelgarten",
  "version": "0.4.4",
  "description": "Zettelkasten note management with configurable ID schemes, derivative note creation, and automatic frontmatter generation.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "zettelkasten",
    "note-taking"
  ],
  "author": "Clinamenic",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.8.0"
  }
}
